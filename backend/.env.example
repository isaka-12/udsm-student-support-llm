# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Ollama
LLM_MODEL=phi3:latest
LLM_API_URL=http://localhost:11434/api/chat

# MongoDB — must match mongoDB/.env credentials
MONGODB_URL=mongodb://<username>:<password>@localhost:27017
MONGODB_DB=udsm_db
SESSION_TTL_DAYS=7

# JWT — generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM tuning (optional)
MAX_HISTORY=20
CONTEXT_WINDOW=10
NUM_CTX=4096
NUM_PREDICT=1000
MAX_CONCURRENT=3
TEMPERATURE=0.3
TOP_P=0.9
REPEAT_PENALTY=1.1

# Logging
LOG_LEVEL=INFO

# RAG — sentence-transformers model (HuggingFace hub ID or local path)
EMBED_MODEL=all-MiniLM-L6-v2
CHROMA_PATH=backend/rag/chroma_db
RAG_TOP_K=3

# CORS — restrict to your frontend origin in production
CORS_ORIGINS=http://localhost:5173
